{
  "scanIgnoreGlobs": [
    "Derived/**",
    "build/**",
    ".build/**",
    "**/Tests/**"
  ],
  "ignoredPathGlobs": [
    "IOS/Application/Services/AppIconService.swift",
    "IOS/Console/Services/AppIconService.swift"
  ],
  "manualReviewPathGlobs": [
    "IOS/AppControls/**",
    "IOS/Packages/AuthKit/**",
    "IOS/Packages/ContactsKit/**",
    "IOS/Packages/LoggerKit/**",
    "IOS/Packages/MirrorKit/**",
    "IOS/Packages/PersistenceKit/**"
  ],
  "ignoredLiteralPatterns": [
    "^AppIcon(Dark|Light)$",
    "^user\\.feedback$",
    "^Analytics event$",
    "^Analytics screen$",
    "^Analytics user property$",
    "^Analytics user id updated$",
    "^This method will no longer be mantained in future versions\\. Please use `draggingAnimation\\(_:\\)` instead$",
    "^Use `startToEnd` instead$",
    "^Use `endToStart` instead$",
    "^10%$",
    "^15%$",
    "^20%$",
    "^25%$"
  ]
}
