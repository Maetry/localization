{
  "name": "localization",
  "version": "1.0.0",
  "description": "Cross-platform localization package with Crowdin integration",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build:all",
    "build:all": "npm run build:ios && npm run build:android && npm run build:web",
    "build:ios": "cd packages/ios && swift build",
    "build:android": "cd packages/android && ./gradlew build",
    "build:web": "cd packages/web && npm run build",
    "swiftgen": "swiftgen config run --config swiftgen.yml",
    "crowdin:init": "node tools/scripts/initial-crowdin-upload.js",
    "crowdin:download": "crowdin download",
    "crowdin:sync": "node tools/scripts/crowdin-sync.js",
    "publish": "node tools/scripts/publish-packages.js"
  },
  "devDependencies": {
    "js-yaml": "^4.1.0",
    "glob": "^10.3.10",
    "chalk": "^4.1.2",
    "commander": "^11.1.0",
    "fs-extra": "^11.1.1"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Maetry/localization.git"
  },
  "keywords": [
    "localization",
    "i18n",
    "l10n",
    "cross-platform",
    "ios",
    "android",
    "web",
    "crowdin",
    "swift",
    "nextjs"
  ],
  "author": "Maetry",
  "license": "MIT"
}
